SEMAFILE=/tmp/xdpfrer-srv6_multi_prf.envs
NSDIR=/tmp/xdpfrer-srv6_multi_prf-mntns

nsrun() { nsenter --net=/var/run/netns/$1 --mount=/proc/$(cat $NSDIR/$1)/ns/mnt -- "${@:2}"; }
alias n1="nsrun n1"
alias n2="nsrun n2"
alias n3="nsrun n3"
alias n4="nsrun n4"
alias n5="nsrun n5"
alias n6="nsrun n6"
alias n7="nsrun n7"
alias n8="nsrun n8"
alias n9="nsrun n9"

ALIASES="NSDIR=$NSDIR; "'nsrun() { nsenter --net=/var/run/netns/$1 --mount=/proc/$(cat $NSDIR/$1)/ns/mnt -- "${@:2}"; }; alias n1="nsrun n1"; alias n2="nsrun n2"; alias n3="nsrun n3"; alias n4="nsrun n4"; alias n5="nsrun n5"; alias n6="nsrun n6"; alias n7="nsrun n7"; alias n8="nsrun n8"; alias n9="nsrun n9"'

if [ $(id -u) -ne 0 ]; then
  echo "Usage: run 'source srv6_multi_prf.env' as root"
  return -1
fi

hosts=(n1 n2 n3 n4 n5 n6 n7 n8 n9)

configure_netenv() {
  echo "Configure test network for XDP PREF multiple replication (SRv6)..."

  mkdir -p $NSDIR

  # Create namespaces with persistent mount namespaces
  for ns in "${hosts[@]}"; do
    ip netns add $ns
    ip netns exec $ns unshare --mount --propagation shared bash -c "
      mount -t bpf bpf /sys/fs/bpf
      echo \$\$ > $NSDIR/$ns
      exec sleep infinity
    " &
    disown
  done

  for ns in "${hosts[@]}"; do
    while [ ! -s $NSDIR/$ns ]; do sleep 0.1; done
  done

  for ns in "${hosts[@]}"; do
    ip netns exec $ns ip link set dev lo up
    ip netns exec $ns sysctl -qw net.ipv6.conf.all.forwarding=1
    ip netns exec $ns sysctl -qw net.ipv6.conf.all.seg6_enabled=1
  done

  # Create links
  # n1-n2
  ip link add eth12 netns n1 type veth peer name eth21 netns n2
  # n2-n3
  ip link add eth23 netns n2 type veth peer name eth32 netns n3
  # n2-n7
  ip link add eth27 netns n2 type veth peer name eth72 netns n7
  # n3-n4
  ip link add eth34 netns n3 type veth peer name eth43 netns n4
  # n4-n5
  ip link add eth45 netns n4 type veth peer name eth54 netns n5
  # n4-n6
  ip link add eth46 netns n4 type veth peer name eth64 netns n6
  # n5-n8
  ip link add eth58 netns n5 type veth peer name eth85 netns n8
  # n6-n8
  ip link add eth68 netns n6 type veth peer name eth86 netns n8
  # n7-n8
  ip link add eth78 netns n7 type veth peer name eth87 netns n8
  # n8-n9
  ip link add eth89 netns n8 type veth peer name eth98 netns n9

  # Bring up all link interfaces
  n1 ip link set dev eth12 up
  n2 ip link set dev eth21 up
  n2 ip link set dev eth23 up
  n3 ip link set dev eth32 up
  n2 ip link set dev eth27 up
  n7 ip link set dev eth72 up
  n3 ip link set dev eth34 up
  n4 ip link set dev eth43 up
  n4 ip link set dev eth45 up
  n5 ip link set dev eth54 up
  n4 ip link set dev eth46 up
  n6 ip link set dev eth64 up
  n5 ip link set dev eth58 up
  n8 ip link set dev eth85 up
  n6 ip link set dev eth68 up
  n8 ip link set dev eth86 up
  n7 ip link set dev eth78 up
  n8 ip link set dev eth87 up
  n8 ip link set dev eth89 up
  n9 ip link set dev eth98 up

  # Enable seg6 on receiving interfaces
  n2 sysctl -qw net.ipv6.conf.eth21.seg6_enabled=1
  n3 sysctl -qw net.ipv6.conf.eth32.seg6_enabled=1
  n4 sysctl -qw net.ipv6.conf.eth43.seg6_enabled=1
  n5 sysctl -qw net.ipv6.conf.eth54.seg6_enabled=1
  n6 sysctl -qw net.ipv6.conf.eth64.seg6_enabled=1
  n7 sysctl -qw net.ipv6.conf.eth72.seg6_enabled=1
  n8 sysctl -qw net.ipv6.conf.eth85.seg6_enabled=1
  n8 sysctl -qw net.ipv6.conf.eth86.seg6_enabled=1
  n8 sysctl -qw net.ipv6.conf.eth87.seg6_enabled=1
  n9 sysctl -qw net.ipv6.conf.eth98.seg6_enabled=1

  # Loopback addresses
  n1 ip addr add 5f00:0:0:1::/128 dev lo
  n2 ip addr add 5f00:0:0:2::/128 dev lo
  n3 ip addr add 5f00:0:0:3::/128 dev lo
  n4 ip addr add 5f00:0:0:4::/128 dev lo
  n5 ip addr add 5f00:0:0:5::/128 dev lo
  n6 ip addr add 5f00:0:0:6::/128 dev lo
  n7 ip addr add 5f00:0:0:7::/128 dev lo
  n8 ip addr add 5f00:0:0:8::/128 dev lo
  n9 ip addr add 5f00:0:0:9::/128 dev lo

  # Link addresses
  # n1-n2
  n1 ip addr add 5f00:0:0:12::1/64 dev eth12
  n2 ip addr add 5f00:0:0:12::2/64 dev eth21
  # n2-n3
  n2 ip addr add 5f00:0:0:23::2/64 dev eth23
  n3 ip addr add 5f00:0:0:23::3/64 dev eth32
  # n2-n7
  n2 ip addr add 5f00:0:0:27::2/64 dev eth27
  n7 ip addr add 5f00:0:0:27::7/64 dev eth72
  # n3-n4
  n3 ip addr add 5f00:0:0:34::3/64 dev eth34
  n4 ip addr add 5f00:0:0:34::4/64 dev eth43
  # n4-n5
  n4 ip addr add 5f00:0:0:45::4/64 dev eth45
  n5 ip addr add 5f00:0:0:45::5/64 dev eth54
  # n4-n6
  n4 ip addr add 5f00:0:0:46::4/64 dev eth46
  n6 ip addr add 5f00:0:0:46::6/64 dev eth64
  # n5-n8
  n5 ip addr add 5f00:0:0:58::5/64 dev eth58
  n8 ip addr add 5f00:0:0:58::8/64 dev eth85
  # n6-n8
  n6 ip addr add 5f00:0:0:68::6/64 dev eth68
  n8 ip addr add 5f00:0:0:68::8/64 dev eth86
  # n7-n8
  n7 ip addr add 5f00:0:0:78::7/64 dev eth78
  n8 ip addr add 5f00:0:0:78::8/64 dev eth87
  # n8-n9
  n8 ip addr add 5f00:0:0:89::8/64 dev eth89
  n9 ip addr add 5f00:0:0:89::9/64 dev eth98

  # Routing
  # n1: default via n2
  n1 ip -6 route add default via 5f00:0:0:12::2 dev eth12

  # n9: default via n8
  n9 ip -6 route add default via 5f00:0:0:89::8 dev eth98

  # n2: forward via n7 (default path "c")
  n2 ip -6 route add 5f00:0:0:78::/64 via 5f00:0:0:27::7 dev eth27
  n2 ip -6 route add 5f00:0:0:89::/64 via 5f00:0:0:27::7 dev eth27
  n2 ip -6 route add 5f00:0:0:7::/64 via 5f00:0:0:27::7 dev eth27
  n2 ip -6 route add 5f00:0:0:8::/64 via 5f00:0:0:27::7 dev eth27
  n2 ip -6 route add 5f00:0:0:9::/64 via 5f00:0:0:27::7 dev eth27
  # n2: via n3
  n2 ip -6 route add 5f00:0:0:34::/64 via 5f00:0:0:23::3 dev eth23
  n2 ip -6 route add 5f00:0:0:45::/64 via 5f00:0:0:23::3 dev eth23
  n2 ip -6 route add 5f00:0:0:46::/64 via 5f00:0:0:23::3 dev eth23
  n2 ip -6 route add 5f00:0:0:58::/64 via 5f00:0:0:23::3 dev eth23
  n2 ip -6 route add 5f00:0:0:68::/64 via 5f00:0:0:23::3 dev eth23
  n2 ip -6 route add 5f00:0:0:3::/64 via 5f00:0:0:23::3 dev eth23
  n2 ip -6 route add 5f00:0:0:4::/64 via 5f00:0:0:23::3 dev eth23
  n2 ip -6 route add 5f00:0:0:5::/64 via 5f00:0:0:23::3 dev eth23
  n2 ip -6 route add 5f00:0:0:6::/64 via 5f00:0:0:23::3 dev eth23
  # n2: reverse (via n1)
  n2 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:12::1 dev eth21

  # n3: forward (via n4)
  n3 ip -6 route add 5f00:0:0:45::/64 via 5f00:0:0:34::4 dev eth34
  n3 ip -6 route add 5f00:0:0:46::/64 via 5f00:0:0:34::4 dev eth34
  n3 ip -6 route add 5f00:0:0:58::/64 via 5f00:0:0:34::4 dev eth34
  n3 ip -6 route add 5f00:0:0:68::/64 via 5f00:0:0:34::4 dev eth34
  n3 ip -6 route add 5f00:0:0:89::/64 via 5f00:0:0:34::4 dev eth34
  n3 ip -6 route add 5f00:0:0:4::/64 via 5f00:0:0:34::4 dev eth34
  n3 ip -6 route add 5f00:0:0:5::/64 via 5f00:0:0:34::4 dev eth34
  n3 ip -6 route add 5f00:0:0:6::/64 via 5f00:0:0:34::4 dev eth34
  n3 ip -6 route add 5f00:0:0:8::/64 via 5f00:0:0:34::4 dev eth34
  n3 ip -6 route add 5f00:0:0:9::/64 via 5f00:0:0:34::4 dev eth34
  # n3: reverse (via n2)
  n3 ip -6 route add 5f00:0:0:12::/64 via 5f00:0:0:23::2 dev eth32
  n3 ip -6 route add 5f00:0:0:27::/64 via 5f00:0:0:23::2 dev eth32
  n3 ip -6 route add 5f00:0:0:78::/64 via 5f00:0:0:23::2 dev eth32
  n3 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:23::2 dev eth32
  n3 ip -6 route add 5f00:0:0:2::/64 via 5f00:0:0:23::2 dev eth32
  n3 ip -6 route add 5f00:0:0:7::/64 via 5f00:0:0:23::2 dev eth32

  # n4: forward via n5 (default path "a")
  n4 ip -6 route add 5f00:0:0:58::/64 via 5f00:0:0:45::5 dev eth45
  n4 ip -6 route add 5f00:0:0:5::/64 via 5f00:0:0:45::5 dev eth45
  # n4: forward via n6 (path "b")
  n4 ip -6 route add 5f00:0:0:68::/64 via 5f00:0:0:46::6 dev eth46
  n4 ip -6 route add 5f00:0:0:6::/64 via 5f00:0:0:46::6 dev eth46
  # n4: forward to n8/n9 (via n5 by default)
  n4 ip -6 route add 5f00:0:0:89::/64 via 5f00:0:0:45::5 dev eth45
  n4 ip -6 route add 5f00:0:0:8::/64 via 5f00:0:0:45::5 dev eth45
  n4 ip -6 route add 5f00:0:0:9::/64 via 5f00:0:0:45::5 dev eth45
  # n4: reverse (via n3)
  n4 ip -6 route add 5f00:0:0:23::/64 via 5f00:0:0:34::3 dev eth43
  n4 ip -6 route add 5f00:0:0:27::/64 via 5f00:0:0:34::3 dev eth43
  n4 ip -6 route add 5f00:0:0:78::/64 via 5f00:0:0:34::3 dev eth43
  n4 ip -6 route add 5f00:0:0:12::/64 via 5f00:0:0:34::3 dev eth43
  n4 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:34::3 dev eth43
  n4 ip -6 route add 5f00:0:0:2::/64 via 5f00:0:0:34::3 dev eth43
  n4 ip -6 route add 5f00:0:0:3::/64 via 5f00:0:0:34::3 dev eth43
  n4 ip -6 route add 5f00:0:0:7::/64 via 5f00:0:0:34::3 dev eth43

  # n5: forward (via n8)
  n5 ip -6 route add 5f00:0:0:89::/64 via 5f00:0:0:58::8 dev eth58
  n5 ip -6 route add 5f00:0:0:8::/64 via 5f00:0:0:58::8 dev eth58
  n5 ip -6 route add 5f00:0:0:9::/64 via 5f00:0:0:58::8 dev eth58
  # n5: reverse (via n4)
  n5 ip -6 route add 5f00:0:0:46::/64 via 5f00:0:0:45::4 dev eth54
  n5 ip -6 route add 5f00:0:0:34::/64 via 5f00:0:0:45::4 dev eth54
  n5 ip -6 route add 5f00:0:0:23::/64 via 5f00:0:0:45::4 dev eth54
  n5 ip -6 route add 5f00:0:0:27::/64 via 5f00:0:0:45::4 dev eth54
  n5 ip -6 route add 5f00:0:0:78::/64 via 5f00:0:0:45::4 dev eth54
  n5 ip -6 route add 5f00:0:0:12::/64 via 5f00:0:0:45::4 dev eth54
  n5 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:45::4 dev eth54
  n5 ip -6 route add 5f00:0:0:2::/64 via 5f00:0:0:45::4 dev eth54
  n5 ip -6 route add 5f00:0:0:3::/64 via 5f00:0:0:45::4 dev eth54
  n5 ip -6 route add 5f00:0:0:4::/64 via 5f00:0:0:45::4 dev eth54
  n5 ip -6 route add 5f00:0:0:6::/64 via 5f00:0:0:45::4 dev eth54
  n5 ip -6 route add 5f00:0:0:7::/64 via 5f00:0:0:45::4 dev eth54

  # n6: forward (via n8)
  n6 ip -6 route add 5f00:0:0:89::/64 via 5f00:0:0:68::8 dev eth68
  n6 ip -6 route add 5f00:0:0:8::/64 via 5f00:0:0:68::8 dev eth68
  n6 ip -6 route add 5f00:0:0:9::/64 via 5f00:0:0:68::8 dev eth68
  # n6: reverse (via n4)
  n6 ip -6 route add 5f00:0:0:45::/64 via 5f00:0:0:46::4 dev eth64
  n6 ip -6 route add 5f00:0:0:34::/64 via 5f00:0:0:46::4 dev eth64
  n6 ip -6 route add 5f00:0:0:23::/64 via 5f00:0:0:46::4 dev eth64
  n6 ip -6 route add 5f00:0:0:27::/64 via 5f00:0:0:46::4 dev eth64
  n6 ip -6 route add 5f00:0:0:78::/64 via 5f00:0:0:46::4 dev eth64
  n6 ip -6 route add 5f00:0:0:12::/64 via 5f00:0:0:46::4 dev eth64
  n6 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:46::4 dev eth64
  n6 ip -6 route add 5f00:0:0:2::/64 via 5f00:0:0:46::4 dev eth64
  n6 ip -6 route add 5f00:0:0:3::/64 via 5f00:0:0:46::4 dev eth64
  n6 ip -6 route add 5f00:0:0:4::/64 via 5f00:0:0:46::4 dev eth64
  n6 ip -6 route add 5f00:0:0:5::/64 via 5f00:0:0:46::4 dev eth64
  n6 ip -6 route add 5f00:0:0:7::/64 via 5f00:0:0:46::4 dev eth64

  # n7: forward (via n8)
  n7 ip -6 route add 5f00:0:0:89::/64 via 5f00:0:0:78::8 dev eth78
  n7 ip -6 route add 5f00:0:0:8::/64 via 5f00:0:0:78::8 dev eth78
  n7 ip -6 route add 5f00:0:0:9::/64 via 5f00:0:0:78::8 dev eth78
  # n7: reverse (via n2)
  n7 ip -6 route add 5f00:0:0:23::/64 via 5f00:0:0:27::2 dev eth72
  n7 ip -6 route add 5f00:0:0:34::/64 via 5f00:0:0:27::2 dev eth72
  n7 ip -6 route add 5f00:0:0:45::/64 via 5f00:0:0:27::2 dev eth72
  n7 ip -6 route add 5f00:0:0:46::/64 via 5f00:0:0:27::2 dev eth72
  n7 ip -6 route add 5f00:0:0:58::/64 via 5f00:0:0:27::2 dev eth72
  n7 ip -6 route add 5f00:0:0:68::/64 via 5f00:0:0:27::2 dev eth72
  n7 ip -6 route add 5f00:0:0:12::/64 via 5f00:0:0:27::2 dev eth72
  n7 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:27::2 dev eth72
  n7 ip -6 route add 5f00:0:0:2::/64 via 5f00:0:0:27::2 dev eth72
  n7 ip -6 route add 5f00:0:0:3::/64 via 5f00:0:0:27::2 dev eth72
  n7 ip -6 route add 5f00:0:0:4::/64 via 5f00:0:0:27::2 dev eth72
  n7 ip -6 route add 5f00:0:0:5::/64 via 5f00:0:0:27::2 dev eth72
  n7 ip -6 route add 5f00:0:0:6::/64 via 5f00:0:0:27::2 dev eth72

  # n8: forward (via n9)
  n8 ip -6 route add 5f00:0:0:9::/64 via 5f00:0:0:89::9 dev eth89
  # n8: reverse via n7 (default, path "c")
  n8 ip -6 route add 5f00:0:0:27::/64 via 5f00:0:0:78::7 dev eth87
  n8 ip -6 route add 5f00:0:0:12::/64 via 5f00:0:0:78::7 dev eth87
  n8 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:78::7 dev eth87
  n8 ip -6 route add 5f00:0:0:2::/64 via 5f00:0:0:78::7 dev eth87
  n8 ip -6 route add 5f00:0:0:7::/64 via 5f00:0:0:78::7 dev eth87
  # n8: reverse via n5 (path "a")
  n8 ip -6 route add 5f00:0:0:45::/64 via 5f00:0:0:58::5 dev eth85
  n8 ip -6 route add 5f00:0:0:34::/64 via 5f00:0:0:58::5 dev eth85
  n8 ip -6 route add 5f00:0:0:23::/64 via 5f00:0:0:58::5 dev eth85
  n8 ip -6 route add 5f00:0:0:5::/64 via 5f00:0:0:58::5 dev eth85
  n8 ip -6 route add 5f00:0:0:4::/64 via 5f00:0:0:58::5 dev eth85
  n8 ip -6 route add 5f00:0:0:3::/64 via 5f00:0:0:58::5 dev eth85
  # n8: reverse via n6 (path "b")
  n8 ip -6 route add 5f00:0:0:46::/64 via 5f00:0:0:68::6 dev eth86
  n8 ip -6 route add 5f00:0:0:6::/64 via 5f00:0:0:68::6 dev eth86

  # SRv6: n2 encapsulates toward n8
  # Path a: n2 -> n3 -> n4 (n4 further replicates into a1 and a2)
  n2 ip -6 route add 5f00:0:0:4:f:1000::/84 encap seg6 mode inline segs 5f00:0:0:3:: dev eth23
  # Path a1: n4 -> n5 -> n8
  n4 ip -6 route add 5f00:0:0:8:f:3000::/84 encap seg6 mode inline segs 5f00:0:0:5:: dev eth45
  # Path a2: n4 -> n6 -> n8
  n4 ip -6 route add 5f00:0:0:8:f:4000::/84 encap seg6 mode inline segs 5f00:0:0:6:: dev eth46
  # Path b: n2 -> n7 -> n8
  n2 ip -6 route add 5f00:0:0:8:f:2000::/84 encap seg6 mode inline segs 5f00:0:0:7:: dev eth27

  # veth0/veth1: path via n3 (toward n4)
  n2 ip link add veth0 type veth peer name veth1
  n2 ip link set veth0 up
  n2 ip link set veth1 up
  n2 sysctl -qw net.ipv6.conf.veth0.seg6_enabled=1
  n2 sysctl -qw net.ipv6.conf.veth1.seg6_enabled=1
  n2 ethtool -K veth0 gro on
  n2 ethtool -K veth1 gro on
  n2 ip link set veth0 address 02:00:00:00:00:00
  n2 ip link set veth1 address 02:00:00:00:00:01

  # veth2/veth3: path "c" (via n7)
  n2 ip link add veth2 type veth peer name veth3
  n2 ip link set veth2 up
  n2 ip link set veth3 up
  n2 sysctl -qw net.ipv6.conf.veth2.seg6_enabled=1
  n2 sysctl -qw net.ipv6.conf.veth3.seg6_enabled=1
  n2 ethtool -K veth2 gro on
  n2 ethtool -K veth3 gro on
  n2 ip link set veth2 address 02:00:00:00:00:00
  n2 ip link set veth3 address 02:00:00:00:00:01

  # veth0/veth1: path "a" (via n5)
  n4 ip link add veth0 type veth peer name veth1
  n4 ip link set veth0 up
  n4 ip link set veth1 up
  n4 sysctl -qw net.ipv6.conf.veth0.seg6_enabled=1
  n4 sysctl -qw net.ipv6.conf.veth1.seg6_enabled=1
  n4 ethtool -K veth0 gro on
  n4 ethtool -K veth1 gro on
  n4 ip link set veth0 address 02:00:00:00:00:00
  n4 ip link set veth1 address 02:00:00:00:00:01

  # veth2/veth3: path "b" (via n6)
  n4 ip link add veth2 type veth peer name veth3
  n4 ip link set veth2 up
  n4 ip link set veth3 up
  n4 sysctl -qw net.ipv6.conf.veth2.seg6_enabled=1
  n4 sysctl -qw net.ipv6.conf.veth3.seg6_enabled=1
  n4 ethtool -K veth2 gro on
  n4 ethtool -K veth3 gro on
  n4 ip link set veth2 address 02:00:00:00:00:00
  n4 ip link set veth3 address 02:00:00:00:00:01

  # veth pair on n8
  n8 ip link add veth0 type veth peer name veth1
  n8 ip link set veth0 up
  n8 ip link set veth1 up
  n8 sysctl -qw net.ipv6.conf.veth0.seg6_enabled=1
  n8 sysctl -qw net.ipv6.conf.veth1.seg6_enabled=1
  n8 ethtool -K veth0 gro on
  n8 ethtool -K veth1 gro on
  n8 ip link set veth0 address 02:00:00:00:00:00
  n8 ip link set veth1 address 02:00:00:00:00:01

  # Disable checksum offload on endpoints
  n1 ethtool -K eth12 tx off rx off
  n9 ethtool -K eth98 tx off rx off

  # Set MTU on transit links for SRv6 encapsulation overhead
  n1 ip link set eth12 mtu 1700
  n2 ip link set eth21 mtu 1700
  n2 ip link set eth23 mtu 1700
  n3 ip link set eth32 mtu 1700
  n2 ip link set eth27 mtu 1700
  n7 ip link set eth72 mtu 1700
  n3 ip link set eth34 mtu 1700
  n4 ip link set eth43 mtu 1700
  n4 ip link set eth45 mtu 1700
  n5 ip link set eth54 mtu 1700
  n4 ip link set eth46 mtu 1700
  n6 ip link set eth64 mtu 1700
  n5 ip link set eth58 mtu 1700
  n8 ip link set eth85 mtu 1700
  n6 ip link set eth68 mtu 1700
  n8 ip link set eth86 mtu 1700
  n7 ip link set eth78 mtu 1700
  n8 ip link set eth87 mtu 1700
  n8 ip link set eth89 mtu 1700
  n9 ip link set eth98 mtu 1700
  n2 ip link set veth0 mtu 1700
  n2 ip link set veth1 mtu 1700
  n2 ip link set veth2 mtu 1700
  n2 ip link set veth3 mtu 1700
  n4 ip link set veth0 mtu 1700
  n4 ip link set veth1 mtu 1700
  n4 ip link set veth2 mtu 1700
  n4 ip link set veth3 mtu 1700
  n8 ip link set veth0 mtu 1700
  n8 ip link set veth1 mtu 1700

  # Endpoint MTU stays at 1500
  n1 ip link set eth12 mtu 1500
  n9 ip link set eth98 mtu 1500

  echo "Done."
}

cleanup() {
  echo "Cleanup XDP PREF multi-prf (SRv6) test network..."

  for ns in "${hosts[@]}"; do
    [ -s $NSDIR/$ns ] && kill $(cat $NSDIR/$ns) 2>/dev/null
    rm -f $NSDIR/$ns
  done

  rmdir $NSDIR 2>/dev/null

  for ns in "${hosts[@]}"; do
    ip netns del $ns 2>/dev/null
  done
}

if [ -f "$SEMAFILE" ]; then
  cntvalue=`cat $SEMAFILE`
  newvalue=`expr $cntvalue + 1`
  echo $newvalue > $SEMAFILE
else
  configure_netenv
  echo "1" > $SEMAFILE
fi

/bin/bash --init-file <(echo "$ALIASES; PS1='(srv6_multi_prf.env) \u:\W# '")

cntvalue=`cat $SEMAFILE`
if [ $cntvalue -eq 1 ]; then
  rm $SEMAFILE
  cleanup
else
  newvalue=`expr $cntvalue - 1`
  echo $newvalue > $SEMAFILE
fi
