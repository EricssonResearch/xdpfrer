SEMAFILE=/tmp/xdpfrer-srv6.envs
NSDIR=/tmp/xdpfrer-srv6-mntns # Directory for storing PIDs of persistent mount namespace holders

# Enter the network and mount namespaces of a node, then run the given command
nsrun() { nsenter --net=/var/run/netns/$1 --mount=/proc/$(cat $NSDIR/$1)/ns/mnt -- "${@:2}"; }
alias na="nsrun na"
alias nb="nsrun nb"
alias nc="nsrun nc"
alias nd="nsrun nd"
alias ne="nsrun ne"
alias nf="nsrun nf"

ALIASES="NSDIR=$NSDIR; "'nsrun() { nsenter --net=/var/run/netns/$1 --mount=/proc/$(cat $NSDIR/$1)/ns/mnt -- "${@:2}"; }; alias na="nsrun na"; alias nb="nsrun nb"; alias nc="nsrun nc"; alias nd="nsrun nd"; alias ne="nsrun ne"; alias nf="nsrun nf"'

hosts=(na nb nc nd ne nf)

if [ $(id -u) -ne 0 ]; then
  echo "Usage: run 'source srv6.env' as root"
  return -1
fi

configure_netenv() {
  echo "Configure test network for XDP PREF (SRv6)..."

  mkdir -p $NSDIR

  # Create namespaces with persistent mount namespaces
  for ns in "${hosts[@]}"; do
    ip netns add $ns
    # Spawn a long-lived process per netns to keep bpffs mounted persistently
    ip netns exec $ns unshare --mount --propagation shared bash -c "
      mount -t bpf bpf /sys/fs/bpf
      echo \$\$ > $NSDIR/$ns
      exec sleep infinity
    " &
    disown
  done

  # Wait for all PIDs to be written
  for ns in "${hosts[@]}"; do
    while [ ! -s $NSDIR/$ns ]; do sleep 0.1; done
  done

  for ns in "${hosts[@]}"; do
    ip netns exec $ns ip link set dev lo up
    ip netns exec $ns sysctl -qw net.ipv6.conf.all.forwarding=1
    ip netns exec $ns sysctl -qw net.ipv6.conf.all.seg6_enabled=1
  done

  # Create links: na-nb, nb-nc, nc-nd, nd-ne, ne-nf
  ip link add ethAB netns na type veth peer name ethBA netns nb
  ip link add ethBC netns nb type veth peer name ethCB netns nc
  ip link add ethCD netns nc type veth peer name ethDC netns nd
  ip link add ethDE netns nd type veth peer name ethED netns ne
  ip link add ethEF netns ne type veth peer name ethFE netns nf

  # Bring up all link interfaces
  na ip link set dev ethAB up
  nb ip link set dev ethBA up
  nb ip link set dev ethBC up
  nc ip link set dev ethCB up
  nc ip link set dev ethCD up
  nd ip link set dev ethDC up
  nd ip link set dev ethDE up
  ne ip link set dev ethED up
  ne ip link set dev ethEF up
  nf ip link set dev ethFE up

  # Enable seg6 on receiving interfaces
  nb sysctl -qw net.ipv6.conf.ethBA.seg6_enabled=1
  nc sysctl -qw net.ipv6.conf.ethCB.seg6_enabled=1
  nd sysctl -qw net.ipv6.conf.ethDC.seg6_enabled=1
  ne sysctl -qw net.ipv6.conf.ethED.seg6_enabled=1
  nf sysctl -qw net.ipv6.conf.ethFE.seg6_enabled=1

  # Loopback addresses
  na ip addr add 5f00:0:0:a::/128 dev lo
  nb ip addr add 5f00:0:0:b::/128 dev lo
  nc ip addr add 5f00:0:0:c::/128 dev lo
  nd ip addr add 5f00:0:0:d::/128 dev lo
  ne ip addr add 5f00:0:0:e::/128 dev lo
  nf ip addr add 5f00:0:0:f::/128 dev lo

  # Link addresses
  na ip addr add 5f00:0:0:ab::a/64 dev ethAB
  nb ip addr add 5f00:0:0:ab::b/64 dev ethBA
  nb ip addr add 5f00:0:0:bc::b/64 dev ethBC
  nc ip addr add 5f00:0:0:bc::c/64 dev ethCB
  nc ip addr add 5f00:0:0:cd::c/64 dev ethCD
  nd ip addr add 5f00:0:0:cd::d/64 dev ethDC
  nd ip addr add 5f00:0:0:de::d/64 dev ethDE
  ne ip addr add 5f00:0:0:de::e/64 dev ethED
  ne ip addr add 5f00:0:0:ef::e/64 dev ethEF
  nf ip addr add 5f00:0:0:ef::f/64 dev ethFE

  # Routing
  # na and nf: default routes
  na ip -6 route add default via 5f00:0:0:ab::b dev ethAB
  nf ip -6 route add default via 5f00:0:0:ef::e dev ethFE

  # nb forward (via nc)
  nb ip -6 route add 5f00:0:0:cd::/64 via 5f00:0:0:bc::c dev ethBC
  nb ip -6 route add 5f00:0:0:de::/64 via 5f00:0:0:bc::c dev ethBC
  nb ip -6 route add 5f00:0:0:ef::/64 via 5f00:0:0:bc::c dev ethBC
  nb ip -6 route add 5f00:0:0:c::/64 via 5f00:0:0:bc::c dev ethBC
  nb ip -6 route add 5f00:0:0:d::/64 via 5f00:0:0:bc::c dev ethBC
  nb ip -6 route add 5f00:0:0:f::/64 via 5f00:0:0:bc::c dev ethBC
  # nb reverse (via na)
  nb ip -6 route add 5f00:0:0:a::/64 via 5f00:0:0:ab::a dev ethBA

  # nc forward (via nd)
  nc ip -6 route add 5f00:0:0:de::/64 via 5f00:0:0:cd::d dev ethCD
  nc ip -6 route add 5f00:0:0:ef::/64 via 5f00:0:0:cd::d dev ethCD
  nc ip -6 route add 5f00:0:0:d::/64 via 5f00:0:0:cd::d dev ethCD
  nc ip -6 route add 5f00:0:0:e::/64 via 5f00:0:0:cd::d dev ethCD
  nc ip -6 route add 5f00:0:0:f::/64 via 5f00:0:0:cd::d dev ethCD
  # nc reverse (via nb)
  nc ip -6 route add 5f00:0:0:ab::/64 via 5f00:0:0:bc::b dev ethCB
  nc ip -6 route add 5f00:0:0:a::/64 via 5f00:0:0:bc::b dev ethCB
  nc ip -6 route add 5f00:0:0:b::/64 via 5f00:0:0:bc::b dev ethCB

  # nd forward (via ne)
  nd ip -6 route add 5f00:0:0:ef::/64 via 5f00:0:0:de::e dev ethDE
  nd ip -6 route add 5f00:0:0:e::/64 via 5f00:0:0:de::e dev ethDE
  nd ip -6 route add 5f00:0:0:f::/64 via 5f00:0:0:de::e dev ethDE
  # nd reverse (via nc)
  nd ip -6 route add 5f00:0:0:bc::/64 via 5f00:0:0:cd::c dev ethDC
  nd ip -6 route add 5f00:0:0:ab::/64 via 5f00:0:0:cd::c dev ethDC
  nd ip -6 route add 5f00:0:0:a::/64 via 5f00:0:0:cd::c dev ethDC
  nd ip -6 route add 5f00:0:0:b::/64 via 5f00:0:0:cd::c dev ethDC
  nd ip -6 route add 5f00:0:0:c::/64 via 5f00:0:0:cd::c dev ethDC

  # ne forward (via nf)
  ne ip -6 route add 5f00:0:0:f::/64 via 5f00:0:0:ef::f dev ethEF
  # ne reverse (via nd)
  ne ip -6 route add 5f00:0:0:cd::/64 via 5f00:0:0:de::d dev ethED
  ne ip -6 route add 5f00:0:0:bc::/64 via 5f00:0:0:de::d dev ethED
  ne ip -6 route add 5f00:0:0:ab::/64 via 5f00:0:0:de::d dev ethED
  ne ip -6 route add 5f00:0:0:a::/64 via 5f00:0:0:de::d dev ethED
  ne ip -6 route add 5f00:0:0:b::/64 via 5f00:0:0:de::d dev ethED
  ne ip -6 route add 5f00:0:0:c::/64 via 5f00:0:0:de::d dev ethED
  ne ip -6 route add 5f00:0:0:d::/64 via 5f00:0:0:de::d dev ethED

  # SRv6: nb encapsulates toward ne via nc, nd
  nb ip -6 route add 5f00:0:0:e::/64 encap seg6 mode inline segs 5f00:0:0:c::,5f00:0:0:d:: dev ethBC

  # veth pair on nb (replication)
  nb ip link add veth0 type veth peer name veth1
  nb ip link set veth0 up
  nb ip link set veth1 up
  nb sysctl -qw net.ipv6.conf.veth0.seg6_enabled=1
  nb sysctl -qw net.ipv6.conf.veth1.seg6_enabled=1
  nb ethtool -K veth0 gro on
  nb ethtool -K veth1 gro on
  nb ip link set veth0 address 02:00:00:00:00:00
  nb ip link set veth1 address 02:00:00:00:00:01

  # veth pair on ne (elimination)
  ne ip link add veth0 type veth peer name veth1
  ne ip link set veth0 up
  ne ip link set veth1 up
  ne sysctl -qw net.ipv6.conf.veth0.seg6_enabled=1
  ne sysctl -qw net.ipv6.conf.veth1.seg6_enabled=1
  ne ethtool -K veth0 gro on
  ne ethtool -K veth1 gro on
  ne ip link set veth0 address 02:00:00:00:00:00
  ne ip link set veth1 address 02:00:00:00:00:01

  echo "Done."
}

cleanup() {
  echo "Cleanup XDP PREF (SRv6) test network..."
  
  # Kill mount namespace holder processes
  for ns in "${hosts[@]}"; do
    [ -s $NSDIR/$ns ] && kill $(cat $NSDIR/$ns) 2>/dev/null
    rm -f $NSDIR/$ns
  done
  
  # Remove PID directory
  rmdir $NSDIR 2>/dev/null
  
  # Delete network namespaces
  for ns in "${hosts[@]}"; do
    ip netns del $ns 2>/dev/null
  done
}

if [ -f "$SEMAFILE" ]; then
  cntvalue=`cat $SEMAFILE`
  newvalue=`expr $cntvalue + 1`
  echo $newvalue > $SEMAFILE
else
  configure_netenv
  echo "1" > $SEMAFILE
fi

/bin/bash --init-file <(echo "$ALIASES; PS1='(srv6.env) \u:\W# '")

cntvalue=`cat $SEMAFILE`
if [ $cntvalue -eq 1 ]; then
  rm $SEMAFILE
  cleanup
else
  newvalue=`expr $cntvalue - 1`
  echo $newvalue > $SEMAFILE
fi
