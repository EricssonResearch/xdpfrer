SEMAFILE=/tmp/xdpfrer-srv6_multi_pef.envs
NSDIR=/tmp/xdpfrer-srv6_multi_pef-mntns

nsrun() { nsenter --net=/var/run/netns/$1 --mount=/proc/$(cat $NSDIR/$1)/ns/mnt -- "${@:2}"; }
alias n1="nsrun n1"
alias n2="nsrun n2"
alias n3="nsrun n3"
alias n4="nsrun n4"
alias n5="nsrun n5"
alias n6="nsrun n6"
alias n7="nsrun n7"

ALIASES="NSDIR=$NSDIR; "'nsrun() { nsenter --net=/var/run/netns/$1 --mount=/proc/$(cat $NSDIR/$1)/ns/mnt -- "${@:2}"; }; alias n1="nsrun n1"; alias n2="nsrun n2"; alias n3="nsrun n3"; alias n4="nsrun n4"; alias n5="nsrun n5"; alias n6="nsrun n6"; alias n7="nsrun n7"'

if [ $(id -u) -ne 0 ]; then
  echo "Usage: run 'source srv6_multi_pef.env' as root"
  return -1
fi

hosts=(n1 n2 n3 n4 n5 n6 n7)

configure_netenv() {
  echo "Configure test network for XDP PREF multiple elimination (SRv6)..."

  mkdir -p $NSDIR

  # Create namespaces with persistent mount namespaces
  for ns in "${hosts[@]}"; do
    ip netns add $ns
    ip netns exec $ns unshare --mount --propagation shared bash -c "
      mount -t bpf bpf /sys/fs/bpf
      echo \$\$ > $NSDIR/$ns
      exec sleep infinity
    " &
    disown
  done

  for ns in "${hosts[@]}"; do
    while [ ! -s $NSDIR/$ns ]; do sleep 0.1; done
  done

  for ns in "${hosts[@]}"; do
    ip netns exec $ns ip link set dev lo up
    ip netns exec $ns sysctl -qw net.ipv6.conf.all.forwarding=1
    ip netns exec $ns sysctl -qw net.ipv6.conf.all.seg6_enabled=1
  done

  # Create links
  # n1-n2
  ip link add eth12 netns n1 type veth peer name eth21 netns n2
  # n2-n3
  ip link add eth23 netns n2 type veth peer name eth32 netns n3
  # n2-n4
  ip link add eth24 netns n2 type veth peer name eth42 netns n4
  # n3-n5
  ip link add eth35 netns n3 type veth peer name eth53 netns n5
  # n4-n5
  ip link add eth45 netns n4 type veth peer name eth54 netns n5
  # n5-n6
  ip link add eth56 netns n5 type veth peer name eth65 netns n6
  # n2-n6
  ip link add eth26 netns n2 type veth peer name eth62 netns n6
  # n6-n7
  ip link add eth67 netns n6 type veth peer name eth76 netns n7

  # Bring up all link interfaces
  n1 ip link set dev eth12 up
  n2 ip link set dev eth21 up
  n2 ip link set dev eth23 up
  n3 ip link set dev eth32 up
  n2 ip link set dev eth24 up
  n4 ip link set dev eth42 up
  n3 ip link set dev eth35 up
  n5 ip link set dev eth53 up
  n4 ip link set dev eth45 up
  n5 ip link set dev eth54 up
  n5 ip link set dev eth56 up
  n6 ip link set dev eth65 up
  n2 ip link set dev eth26 up
  n6 ip link set dev eth62 up
  n6 ip link set dev eth67 up
  n7 ip link set dev eth76 up

  # Enable seg6 on receiving interfaces
  n2 sysctl -qw net.ipv6.conf.eth21.seg6_enabled=1
  n3 sysctl -qw net.ipv6.conf.eth32.seg6_enabled=1
  n4 sysctl -qw net.ipv6.conf.eth42.seg6_enabled=1
  n5 sysctl -qw net.ipv6.conf.eth53.seg6_enabled=1
  n5 sysctl -qw net.ipv6.conf.eth54.seg6_enabled=1
  n6 sysctl -qw net.ipv6.conf.eth65.seg6_enabled=1
  n6 sysctl -qw net.ipv6.conf.eth62.seg6_enabled=1
  n7 sysctl -qw net.ipv6.conf.eth76.seg6_enabled=1

  # Loopback addresses
  n1 ip addr add 5f00:0:0:1::/128 dev lo
  n2 ip addr add 5f00:0:0:2::/128 dev lo
  n3 ip addr add 5f00:0:0:3::/128 dev lo
  n4 ip addr add 5f00:0:0:4::/128 dev lo
  n5 ip addr add 5f00:0:0:5::/128 dev lo
  n6 ip addr add 5f00:0:0:6::/128 dev lo
  n7 ip addr add 5f00:0:0:7::/128 dev lo

  # Link addresses
  # n1-n2
  n1 ip addr add 5f00:0:0:12::1/64 dev eth12
  n2 ip addr add 5f00:0:0:12::2/64 dev eth21
  # n2-n3
  n2 ip addr add 5f00:0:0:23::2/64 dev eth23
  n3 ip addr add 5f00:0:0:23::3/64 dev eth32
  # n2-n4
  n2 ip addr add 5f00:0:0:24::2/64 dev eth24
  n4 ip addr add 5f00:0:0:24::4/64 dev eth42
  # n3-n5
  n3 ip addr add 5f00:0:0:35::3/64 dev eth35
  n5 ip addr add 5f00:0:0:35::5/64 dev eth53
  # n4-n5
  n4 ip addr add 5f00:0:0:45::4/64 dev eth45
  n5 ip addr add 5f00:0:0:45::5/64 dev eth54
  # n5-n6
  n5 ip addr add 5f00:0:0:56::5/64 dev eth56
  n6 ip addr add 5f00:0:0:56::6/64 dev eth65
  # n2-n6
  n2 ip addr add 5f00:0:0:26::2/64 dev eth26
  n6 ip addr add 5f00:0:0:26::6/64 dev eth62
  # n6-n7
  n6 ip addr add 5f00:0:0:67::6/64 dev eth67
  n7 ip addr add 5f00:0:0:67::7/64 dev eth76

  # Routing
  # n1: default via n2
  n1 ip -6 route add default via 5f00:0:0:12::2 dev eth12

  # n7: default via n6
  n7 ip -6 route add default via 5f00:0:0:67::6 dev eth76

  # n2: forward default via n6 (n1 -> n2 -> n6 -> n7)
  n2 ip -6 route add 5f00:0:0:67::/64 via 5f00:0:0:26::6 dev eth26
  n2 ip -6 route add 5f00:0:0:6::/64 via 5f00:0:0:26::6 dev eth26
  n2 ip -6 route add 5f00:0:0:7::/64 via 5f00:0:0:26::6 dev eth26
  # n2: via n3
  n2 ip -6 route add 5f00:0:0:3::/64 via 5f00:0:0:23::3 dev eth23
  n2 ip -6 route add 5f00:0:0:35::/64 via 5f00:0:0:23::3 dev eth23
  # n2: via n4
  n2 ip -6 route add 5f00:0:0:4::/64 via 5f00:0:0:24::4 dev eth24
  n2 ip -6 route add 5f00:0:0:45::/64 via 5f00:0:0:24::4 dev eth24
  # n2: via n3 for n5 (default path to n5)
  n2 ip -6 route add 5f00:0:0:5::/64 via 5f00:0:0:23::3 dev eth23
  n2 ip -6 route add 5f00:0:0:56::/64 via 5f00:0:0:23::3 dev eth23
  # n2: reverse (via n1)
  n2 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:12::1 dev eth21

  # n3: forward (via n5)
  n3 ip -6 route add 5f00:0:0:5::/64 via 5f00:0:0:35::5 dev eth35
  n3 ip -6 route add 5f00:0:0:56::/64 via 5f00:0:0:35::5 dev eth35
  n3 ip -6 route add 5f00:0:0:6::/64 via 5f00:0:0:35::5 dev eth35
  n3 ip -6 route add 5f00:0:0:67::/64 via 5f00:0:0:35::5 dev eth35
  n3 ip -6 route add 5f00:0:0:7::/64 via 5f00:0:0:35::5 dev eth35
  # n3: reverse (via n2)
  n3 ip -6 route add 5f00:0:0:12::/64 via 5f00:0:0:23::2 dev eth32
  n3 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:23::2 dev eth32
  n3 ip -6 route add 5f00:0:0:2::/64 via 5f00:0:0:23::2 dev eth32

  # n4: forward (via n5)
  n4 ip -6 route add 5f00:0:0:5::/64 via 5f00:0:0:45::5 dev eth45
  n4 ip -6 route add 5f00:0:0:56::/64 via 5f00:0:0:45::5 dev eth45
  n4 ip -6 route add 5f00:0:0:6::/64 via 5f00:0:0:45::5 dev eth45
  n4 ip -6 route add 5f00:0:0:67::/64 via 5f00:0:0:45::5 dev eth45
  n4 ip -6 route add 5f00:0:0:7::/64 via 5f00:0:0:45::5 dev eth45
  # n4: reverse (via n2)
  n4 ip -6 route add 5f00:0:0:12::/64 via 5f00:0:0:24::2 dev eth42
  n4 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:24::2 dev eth42
  n4 ip -6 route add 5f00:0:0:2::/64 via 5f00:0:0:24::2 dev eth42

  # n5: forward (via n6)
  n5 ip -6 route add 5f00:0:0:6::/64 via 5f00:0:0:56::6 dev eth56
  n5 ip -6 route add 5f00:0:0:67::/64 via 5f00:0:0:56::6 dev eth56
  n5 ip -6 route add 5f00:0:0:7::/64 via 5f00:0:0:56::6 dev eth56
  # n5: reverse via n3
  n5 ip -6 route add 5f00:0:0:23::/64 via 5f00:0:0:35::3 dev eth53
  n5 ip -6 route add 5f00:0:0:12::/64 via 5f00:0:0:35::3 dev eth53
  n5 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:35::3 dev eth53
  n5 ip -6 route add 5f00:0:0:2::/64 via 5f00:0:0:35::3 dev eth53
  n5 ip -6 route add 5f00:0:0:3::/64 via 5f00:0:0:35::3 dev eth53
  # n5: reverse via n4
  n5 ip -6 route add 5f00:0:0:24::/64 via 5f00:0:0:45::4 dev eth54
  n5 ip -6 route add 5f00:0:0:4::/64 via 5f00:0:0:45::4 dev eth54

  # n6: forward (via n7)
  n6 ip -6 route add 5f00:0:0:7::/64 via 5f00:0:0:67::7 dev eth67
  # n6: reverse default via n2 (n7 -> n6 -> n2 -> n1)
  n6 ip -6 route add 5f00:0:0:12::/64 via 5f00:0:0:26::2 dev eth62
  n6 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:26::2 dev eth62
  n6 ip -6 route add 5f00:0:0:2::/64 via 5f00:0:0:26::2 dev eth62
  # n6: reverse via n5
  n6 ip -6 route add 5f00:0:0:35::/64 via 5f00:0:0:56::5 dev eth65
  n6 ip -6 route add 5f00:0:0:45::/64 via 5f00:0:0:56::5 dev eth65
  n6 ip -6 route add 5f00:0:0:23::/64 via 5f00:0:0:56::5 dev eth65
  n6 ip -6 route add 5f00:0:0:24::/64 via 5f00:0:0:56::5 dev eth65
  n6 ip -6 route add 5f00:0:0:3::/64 via 5f00:0:0:56::5 dev eth65
  n6 ip -6 route add 5f00:0:0:4::/64 via 5f00:0:0:56::5 dev eth65
  n6 ip -6 route add 5f00:0:0:5::/64 via 5f00:0:0:56::5 dev eth65

  # SRv6: n2 encapsulates toward n6
  # Path a: n2 -> n3 -> n5 -> n6 (segs n3, n5)
  n2 ip -6 route add 5f00:0:0:5:f:1000::/84 encap seg6 mode inline segs 5f00:0:0:3:: dev eth23
  # Path b: n2 -> n4 -> n5 -> n6 (segs n4, n5)
  n2 ip -6 route add 5f00:0:0:5:f:2000::/84 encap seg6 mode inline segs 5f00:0:0:4:: dev eth24
  # Path c: n2 -> n6 (direct)
  n2 ip -6 route add 5f00:0:0:6:f:3000::/84 via 5f00:0:0:26::6 dev eth26

  # veth pairs on n2 (prf - 3 paths)
  # veth0/veth1: path a (via n3, n5)
  n2 ip link add veth0 type veth peer name veth1
  n2 ip link set veth0 up
  n2 ip link set veth1 up
  n2 sysctl -qw net.ipv6.conf.veth0.seg6_enabled=1
  n2 sysctl -qw net.ipv6.conf.veth1.seg6_enabled=1
  n2 ethtool -K veth0 gro on
  n2 ethtool -K veth1 gro on
  n2 ip link set veth0 address 02:00:00:00:00:00
  n2 ip link set veth1 address 02:00:00:00:00:01

  # veth2/veth3: path b (via n4, n5)
  n2 ip link add veth2 type veth peer name veth3
  n2 ip link set veth2 up
  n2 ip link set veth3 up
  n2 sysctl -qw net.ipv6.conf.veth2.seg6_enabled=1
  n2 sysctl -qw net.ipv6.conf.veth3.seg6_enabled=1
  n2 ethtool -K veth2 gro on
  n2 ethtool -K veth3 gro on
  n2 ip link set veth2 address 02:00:00:00:00:00
  n2 ip link set veth3 address 02:00:00:00:00:01

  # veth4/veth5: path c (direct to n6)
  n2 ip link add veth4 type veth peer name veth5
  n2 ip link set veth4 up
  n2 ip link set veth5 up
  n2 sysctl -qw net.ipv6.conf.veth4.seg6_enabled=1
  n2 sysctl -qw net.ipv6.conf.veth5.seg6_enabled=1
  n2 ethtool -K veth4 gro on
  n2 ethtool -K veth5 gro on
  n2 ip link set veth4 address 02:00:00:00:00:00
  n2 ip link set veth5 address 02:00:00:00:00:01

  # veth pair on n5 (pef - intermediate elimination)
  n5 ip link add veth0 type veth peer name veth1
  n5 ip link set veth0 up
  n5 ip link set veth1 up
  n5 sysctl -qw net.ipv6.conf.veth0.seg6_enabled=1
  n5 sysctl -qw net.ipv6.conf.veth1.seg6_enabled=1
  n5 ethtool -K veth0 gro on
  n5 ethtool -K veth1 gro on
  n5 ip link set veth0 address 02:00:00:00:00:00
  n5 ip link set veth1 address 02:00:00:00:00:01

  # veth pair on n6 (pef - final elimination)
  n6 ip link add veth0 type veth peer name veth1
  n6 ip link set veth0 up
  n6 ip link set veth1 up
  n6 sysctl -qw net.ipv6.conf.veth0.seg6_enabled=1
  n6 sysctl -qw net.ipv6.conf.veth1.seg6_enabled=1
  n6 ethtool -K veth0 gro on
  n6 ethtool -K veth1 gro on
  n6 ip link set veth0 address 02:00:00:00:00:00
  n6 ip link set veth1 address 02:00:00:00:00:01

  # Disable checksum offload on endpoints
  n1 ethtool -K eth12 tx off rx off
  n7 ethtool -K eth76 tx off rx off

  # Set MTU on transit links for SRv6 encapsulation overhead
  n1 ip link set eth12 mtu 1700
  n2 ip link set eth21 mtu 1700
  n2 ip link set eth23 mtu 1700
  n3 ip link set eth32 mtu 1700
  n2 ip link set eth24 mtu 1700
  n4 ip link set eth42 mtu 1700
  n3 ip link set eth35 mtu 1700
  n5 ip link set eth53 mtu 1700
  n4 ip link set eth45 mtu 1700
  n5 ip link set eth54 mtu 1700
  n5 ip link set eth56 mtu 1700
  n6 ip link set eth65 mtu 1700
  n2 ip link set eth26 mtu 1700
  n6 ip link set eth62 mtu 1700
  n6 ip link set eth67 mtu 1700
  n7 ip link set eth76 mtu 1700
  n2 ip link set veth0 mtu 1700
  n2 ip link set veth1 mtu 1700
  n2 ip link set veth2 mtu 1700
  n2 ip link set veth3 mtu 1700
  n2 ip link set veth4 mtu 1700
  n2 ip link set veth5 mtu 1700
  n5 ip link set veth0 mtu 1700
  n5 ip link set veth1 mtu 1700
  n6 ip link set veth0 mtu 1700
  n6 ip link set veth1 mtu 1700

  # Endpoint MTU stays at 1500
  n1 ip link set eth12 mtu 1500
  n7 ip link set eth76 mtu 1500

  echo "Done."
}

cleanup() {
  echo "Cleanup XDP PREF multi-pef (SRv6) test network..."

  for ns in "${hosts[@]}"; do
    [ -s $NSDIR/$ns ] && kill $(cat $NSDIR/$ns) 2>/dev/null
    rm -f $NSDIR/$ns
  done

  rmdir $NSDIR 2>/dev/null

  for ns in "${hosts[@]}"; do
    ip netns del $ns 2>/dev/null
  done
}

if [ -f "$SEMAFILE" ]; then
  cntvalue=`cat $SEMAFILE`
  newvalue=`expr $cntvalue + 1`
  echo $newvalue > $SEMAFILE
else
  configure_netenv
  echo "1" > $SEMAFILE
fi

/bin/bash --init-file <(echo "$ALIASES; PS1='(srv6_multi_pef.env) \u:\W# '")

cntvalue=`cat $SEMAFILE`
if [ $cntvalue -eq 1 ]; then
  rm $SEMAFILE
  cleanup
else
  newvalue=`expr $cntvalue - 1`
  echo $newvalue > $SEMAFILE
fi
