SEMAFILE=/tmp/xdpfrer-srv6.envs
NSDIR=/tmp/xdpfrer-srv6-mntns # Directory for storing PIDs of persistent mount namespace holders

# Enter the network and mount namespaces of a node, then run the given command
nsrun() { nsenter --net=/var/run/netns/$1 --mount=/proc/$(cat $NSDIR/$1)/ns/mnt -- "${@:2}"; }
alias n1="nsrun n1"
alias n2="nsrun n2"
alias n3="nsrun n3"
alias n4="nsrun n4"
alias n5="nsrun n5"
alias n6="nsrun n6"
alias n7="nsrun n7"
alias n8="nsrun n8"
alias n9="nsrun n9"

ALIASES="NSDIR=$NSDIR; "'nsrun() { nsenter --net=/var/run/netns/$1 --mount=/proc/$(cat $NSDIR/$1)/ns/mnt -- "${@:2}"; }; alias n1="nsrun n1"; alias n2="nsrun n2"; alias n3="nsrun n3"; alias n4="nsrun n4"; alias n5="nsrun n5"; alias n6="nsrun n6"; alias n7="nsrun n7"; alias n8="nsrun n8"; alias n9="nsrun n9"'

if [ $(id -u) -ne 0 ]; then
  echo "Usage: run 'source srv6.env' as root"
  return -1
fi

hosts=(n1 n2 n3 n4 n5 n6 n7 n8 n9)

configure_netenv() {
  echo "Configure test network for XDP PREF (SRv6)..."

  mkdir -p $NSDIR

  # Create namespaces with persistent mount namespaces
  for ns in "${hosts[@]}"; do
    ip netns add $ns
    # Spawn a long-lived process per netns to keep bpffs mounted persistently
    ip netns exec $ns unshare --mount --propagation shared bash -c "
      mount -t bpf bpf /sys/fs/bpf
      echo \$\$ > $NSDIR/$ns
      exec sleep infinity
    " &
    disown
  done

  # Wait for all PIDs to be written
  for ns in "${hosts[@]}"; do
    while [ ! -s $NSDIR/$ns ]; do sleep 0.1; done
  done

  for ns in "${hosts[@]}"; do
    ip netns exec $ns ip link set dev lo up
    ip netns exec $ns sysctl -qw net.ipv6.conf.all.forwarding=1
    ip netns exec $ns sysctl -qw net.ipv6.conf.all.seg6_enabled=1
  done

  # Create links
  # n1-n2
  ip link add eth12 netns n1 type veth peer name eth21 netns n2
  # upper path: n2-n3, n3-n4, n4-n8
  ip link add eth23 netns n2 type veth peer name eth32 netns n3
  ip link add eth34 netns n3 type veth peer name eth43 netns n4
  ip link add eth48 netns n4 type veth peer name eth84 netns n8
  # lower path: n2-n5, n5-n6, n6-n7, n7-n8
  ip link add eth25 netns n2 type veth peer name eth52 netns n5
  ip link add eth56 netns n5 type veth peer name eth65 netns n6
  ip link add eth67 netns n6 type veth peer name eth76 netns n7
  ip link add eth78 netns n7 type veth peer name eth87 netns n8
  # n8-n9
  ip link add eth89 netns n8 type veth peer name eth98 netns n9

  # Bring up all link interfaces
  n1 ip link set dev eth12 up
  n2 ip link set dev eth21 up
  n2 ip link set dev eth23 up
  n3 ip link set dev eth32 up
  n3 ip link set dev eth34 up
  n4 ip link set dev eth43 up
  n4 ip link set dev eth48 up
  n8 ip link set dev eth84 up
  n2 ip link set dev eth25 up
  n5 ip link set dev eth52 up
  n5 ip link set dev eth56 up
  n6 ip link set dev eth65 up
  n6 ip link set dev eth67 up
  n7 ip link set dev eth76 up
  n7 ip link set dev eth78 up
  n8 ip link set dev eth87 up
  n8 ip link set dev eth89 up
  n9 ip link set dev eth98 up

  # Enable seg6 on receiving interfaces
  n2 sysctl -qw net.ipv6.conf.eth21.seg6_enabled=1
  n3 sysctl -qw net.ipv6.conf.eth32.seg6_enabled=1
  n4 sysctl -qw net.ipv6.conf.eth43.seg6_enabled=1
  n8 sysctl -qw net.ipv6.conf.eth84.seg6_enabled=1
  n5 sysctl -qw net.ipv6.conf.eth52.seg6_enabled=1
  n6 sysctl -qw net.ipv6.conf.eth65.seg6_enabled=1
  n7 sysctl -qw net.ipv6.conf.eth76.seg6_enabled=1
  n8 sysctl -qw net.ipv6.conf.eth87.seg6_enabled=1
  n9 sysctl -qw net.ipv6.conf.eth98.seg6_enabled=1

  # Loopback addresses
  n1 ip addr add 5f00:0:0:1::/128 dev lo
  n2 ip addr add 5f00:0:0:2::/128 dev lo
  n3 ip addr add 5f00:0:0:3::/128 dev lo
  n4 ip addr add 5f00:0:0:4::/128 dev lo
  n5 ip addr add 5f00:0:0:5::/128 dev lo
  n6 ip addr add 5f00:0:0:6::/128 dev lo
  n7 ip addr add 5f00:0:0:7::/128 dev lo
  n8 ip addr add 5f00:0:0:8::/128 dev lo
  n9 ip addr add 5f00:0:0:9::/128 dev lo

  # Link addresses
  # n1-n2
  n1 ip addr add 5f00:0:0:12::1/64 dev eth12
  n2 ip addr add 5f00:0:0:12::2/64 dev eth21
  # upper path
  n2 ip addr add 5f00:0:0:23::2/64 dev eth23
  n3 ip addr add 5f00:0:0:23::3/64 dev eth32
  n3 ip addr add 5f00:0:0:34::3/64 dev eth34
  n4 ip addr add 5f00:0:0:34::4/64 dev eth43
  n4 ip addr add 5f00:0:0:48::4/64 dev eth48
  n8 ip addr add 5f00:0:0:48::8/64 dev eth84
  # lower path
  n2 ip addr add 5f00:0:0:25::2/64 dev eth25
  n5 ip addr add 5f00:0:0:25::5/64 dev eth52
  n5 ip addr add 5f00:0:0:56::5/64 dev eth56
  n6 ip addr add 5f00:0:0:56::6/64 dev eth65
  n6 ip addr add 5f00:0:0:67::6/64 dev eth67
  n7 ip addr add 5f00:0:0:67::7/64 dev eth76
  n7 ip addr add 5f00:0:0:78::7/64 dev eth78
  n8 ip addr add 5f00:0:0:78::8/64 dev eth87
  # n8-n9
  n8 ip addr add 5f00:0:0:89::8/64 dev eth89
  n9 ip addr add 5f00:0:0:89::9/64 dev eth98

  # Routing
  # n1 and n9: default routes
  n1 ip -6 route add default via 5f00:0:0:12::2 dev eth12
  n9 ip -6 route add default via 5f00:0:0:89::8 dev eth98

  # n2: forward via upper path (default for reaching n8/n9)
  n2 ip -6 route add 5f00:0:0:34::/64 via 5f00:0:0:23::3 dev eth23
  n2 ip -6 route add 5f00:0:0:48::/64 via 5f00:0:0:23::3 dev eth23
  n2 ip -6 route add 5f00:0:0:89::/64 via 5f00:0:0:23::3 dev eth23
  n2 ip -6 route add 5f00:0:0:3::/64 via 5f00:0:0:23::3 dev eth23
  n2 ip -6 route add 5f00:0:0:4::/64 via 5f00:0:0:23::3 dev eth23
  #n2 ip -6 route add 5f00:0:0:8::/64 via 5f00:0:0:23::3 dev eth23
  n2 ip -6 route add 5f00:0:0:9::/64 via 5f00:0:0:23::3 dev eth23
  # n2: forward via lower path
  n2 ip -6 route add 5f00:0:0:56::/64 via 5f00:0:0:25::5 dev eth25
  n2 ip -6 route add 5f00:0:0:67::/64 via 5f00:0:0:25::5 dev eth25
  n2 ip -6 route add 5f00:0:0:78::/64 via 5f00:0:0:25::5 dev eth25
  n2 ip -6 route add 5f00:0:0:5::/64 via 5f00:0:0:25::5 dev eth25
  n2 ip -6 route add 5f00:0:0:6::/64 via 5f00:0:0:25::5 dev eth25
  n2 ip -6 route add 5f00:0:0:7::/64 via 5f00:0:0:25::5 dev eth25
  # n2: reverse (via n1)
  n2 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:12::1 dev eth21

  # n3: forward (via n4)
  n3 ip -6 route add 5f00:0:0:48::/64 via 5f00:0:0:34::4 dev eth34
  n3 ip -6 route add 5f00:0:0:89::/64 via 5f00:0:0:34::4 dev eth34
  n3 ip -6 route add 5f00:0:0:4::/64 via 5f00:0:0:34::4 dev eth34
  n3 ip -6 route add 5f00:0:0:8::/64 via 5f00:0:0:34::4 dev eth34
  n3 ip -6 route add 5f00:0:0:9::/64 via 5f00:0:0:34::4 dev eth34
  # n3: reverse (via n2)
  n3 ip -6 route add 5f00:0:0:12::/64 via 5f00:0:0:23::2 dev eth32
  n3 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:23::2 dev eth32
  n3 ip -6 route add 5f00:0:0:2::/64 via 5f00:0:0:23::2 dev eth32

  # n4: forward (via n8)
  n4 ip -6 route add 5f00:0:0:89::/64 via 5f00:0:0:48::8 dev eth48
  n4 ip -6 route add 5f00:0:0:8::/64 via 5f00:0:0:48::8 dev eth48
  n4 ip -6 route add 5f00:0:0:9::/64 via 5f00:0:0:48::8 dev eth48
  # n4: reverse (via n3)
  n4 ip -6 route add 5f00:0:0:23::/64 via 5f00:0:0:34::3 dev eth43
  n4 ip -6 route add 5f00:0:0:12::/64 via 5f00:0:0:34::3 dev eth43
  n4 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:34::3 dev eth43
  n4 ip -6 route add 5f00:0:0:2::/64 via 5f00:0:0:34::3 dev eth43
  n4 ip -6 route add 5f00:0:0:3::/64 via 5f00:0:0:34::3 dev eth43

  # n5: forward (via n6)
  n5 ip -6 route add 5f00:0:0:67::/64 via 5f00:0:0:56::6 dev eth56
  n5 ip -6 route add 5f00:0:0:78::/64 via 5f00:0:0:56::6 dev eth56
  n5 ip -6 route add 5f00:0:0:6::/64 via 5f00:0:0:56::6 dev eth56
  n5 ip -6 route add 5f00:0:0:7::/64 via 5f00:0:0:56::6 dev eth56
  n5 ip -6 route add 5f00:0:0:8::/64 via 5f00:0:0:56::6 dev eth56
  n5 ip -6 route add 5f00:0:0:9::/64 via 5f00:0:0:56::6 dev eth56
  # n5: reverse (via n2)
  n5 ip -6 route add 5f00:0:0:12::/64 via 5f00:0:0:25::2 dev eth52
  n5 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:25::2 dev eth52
  n5 ip -6 route add 5f00:0:0:2::/64 via 5f00:0:0:25::2 dev eth52

  # n6: forward (via n7)
  n6 ip -6 route add 5f00:0:0:78::/64 via 5f00:0:0:67::7 dev eth67
  n6 ip -6 route add 5f00:0:0:89::/64 via 5f00:0:0:67::7 dev eth67
  n6 ip -6 route add 5f00:0:0:7::/64 via 5f00:0:0:67::7 dev eth67
  n6 ip -6 route add 5f00:0:0:8::/64 via 5f00:0:0:67::7 dev eth67
  n6 ip -6 route add 5f00:0:0:9::/64 via 5f00:0:0:67::7 dev eth67
  # n6: reverse (via n5)
  n6 ip -6 route add 5f00:0:0:25::/64 via 5f00:0:0:56::5 dev eth65
  n6 ip -6 route add 5f00:0:0:12::/64 via 5f00:0:0:56::5 dev eth65
  n6 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:56::5 dev eth65
  n6 ip -6 route add 5f00:0:0:2::/64 via 5f00:0:0:56::5 dev eth65
  n6 ip -6 route add 5f00:0:0:5::/64 via 5f00:0:0:56::5 dev eth65

  # n7: forward (via n8)
  n7 ip -6 route add 5f00:0:0:89::/64 via 5f00:0:0:78::8 dev eth78
  n7 ip -6 route add 5f00:0:0:8::/64 via 5f00:0:0:78::8 dev eth78
  n7 ip -6 route add 5f00:0:0:9::/64 via 5f00:0:0:78::8 dev eth78
  # n7: reverse (via n6)
  n7 ip -6 route add 5f00:0:0:56::/64 via 5f00:0:0:67::6 dev eth76
  n7 ip -6 route add 5f00:0:0:25::/64 via 5f00:0:0:67::6 dev eth76
  n7 ip -6 route add 5f00:0:0:12::/64 via 5f00:0:0:67::6 dev eth76
  n7 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:67::6 dev eth76
  n7 ip -6 route add 5f00:0:0:2::/64 via 5f00:0:0:67::6 dev eth76
  n7 ip -6 route add 5f00:0:0:5::/64 via 5f00:0:0:67::6 dev eth76
  n7 ip -6 route add 5f00:0:0:6::/64 via 5f00:0:0:67::6 dev eth76

  # n8: forward (via n9)
  n8 ip -6 route add 5f00:0:0:9::/64 via 5f00:0:0:89::9 dev eth89
  # n8: reverse via upper (n4)
  n8 ip -6 route add 5f00:0:0:34::/64 via 5f00:0:0:48::4 dev eth84
  n8 ip -6 route add 5f00:0:0:23::/64 via 5f00:0:0:48::4 dev eth84
  n8 ip -6 route add 5f00:0:0:12::/64 via 5f00:0:0:48::4 dev eth84
  n8 ip -6 route add 5f00:0:0:1::/64 via 5f00:0:0:48::4 dev eth84
  n8 ip -6 route add 5f00:0:0:2::/64 via 5f00:0:0:48::4 dev eth84
  n8 ip -6 route add 5f00:0:0:3::/64 via 5f00:0:0:48::4 dev eth84
  n8 ip -6 route add 5f00:0:0:4::/64 via 5f00:0:0:48::4 dev eth84
  # n8: reverse via lower (n7)
  n8 ip -6 route add 5f00:0:0:67::/64 via 5f00:0:0:78::7 dev eth87
  n8 ip -6 route add 5f00:0:0:56::/64 via 5f00:0:0:78::7 dev eth87
  n8 ip -6 route add 5f00:0:0:25::/64 via 5f00:0:0:78::7 dev eth87
  n8 ip -6 route add 5f00:0:0:5::/64 via 5f00:0:0:78::7 dev eth87
  n8 ip -6 route add 5f00:0:0:6::/64 via 5f00:0:0:78::7 dev eth87
  n8 ip -6 route add 5f00:0:0:7::/64 via 5f00:0:0:78::7 dev eth87

  # SRv6: n2 encapsulates toward n8
  # Upper path (via n3, n4)
  n2 ip -6 route add 5f00:0:0:8:a::/80 encap seg6 mode inline segs 5f00:0:0:3::,5f00:0:0:4:: dev eth23
  # Lower path (via n5, n6, n7)
  n2 ip -6 route add 5f00:0:0:8:b::/80 encap seg6 mode inline segs 5f00:0:0:5::,5f00:0:0:6::,5f00:0:0:7:: dev eth25

  # veth0/veth1 on n2 (replication - upper path)
  n2 ip link add veth0 type veth peer name veth1
  n2 ip link set veth0 up
  n2 ip link set veth1 up
  n2 sysctl -qw net.ipv6.conf.veth0.seg6_enabled=1
  n2 sysctl -qw net.ipv6.conf.veth1.seg6_enabled=1
  n2 ethtool -K veth0 gro on
  n2 ethtool -K veth1 gro on
  n2 ip link set veth0 address 02:00:00:00:00:00
  n2 ip link set veth1 address 02:00:00:00:00:01  

  # veth2/veth3 on n2 (replication - lower path)
  n2 ip link add veth2 type veth peer name veth3
  n2 ip link set veth2 up
  n2 ip link set veth3 up
  n2 sysctl -qw net.ipv6.conf.veth2.seg6_enabled=1
  n2 sysctl -qw net.ipv6.conf.veth3.seg6_enabled=1
  n2 ethtool -K veth2 gro on
  n2 ethtool -K veth3 gro on
  n2 ip link set veth2 address 02:00:00:00:00:00
  n2 ip link set veth3 address 02:00:00:00:00:01

  # veth pair on n8 (elimination / pef)
  n8 ip link add veth0 type veth peer name veth1
  n8 ip link set veth0 up
  n8 ip link set veth1 up
  n8 sysctl -qw net.ipv6.conf.veth0.seg6_enabled=1
  n8 sysctl -qw net.ipv6.conf.veth1.seg6_enabled=1
  n8 ethtool -K veth0 gro on
  n8 ethtool -K veth1 gro on
  n8 ip link set veth0 address 02:00:00:00:00:00
  n8 ip link set veth1 address 02:00:00:00:00:01

  echo "Done."
}

cleanup() {
  echo "Cleanup XDP PREF (SRv6) test network..."

  # Kill mount namespace holder processes
  for ns in "${hosts[@]}"; do
    [ -s $NSDIR/$ns ] && kill $(cat $NSDIR/$ns) 2>/dev/null
    rm -f $NSDIR/$ns
  done

  # Remove PID directory
  rmdir $NSDIR 2>/dev/null

  # Delete network namespaces
  for ns in "${hosts[@]}"; do
    ip netns del $ns 2>/dev/null
  done
}

if [ -f "$SEMAFILE" ]; then
  cntvalue=`cat $SEMAFILE`
  newvalue=`expr $cntvalue + 1`
  echo $newvalue > $SEMAFILE
else
  configure_netenv
  echo "1" > $SEMAFILE
fi

/bin/bash --init-file <(echo "$ALIASES; PS1='(srv6.env) \u:\W# '")

cntvalue=`cat $SEMAFILE`
if [ $cntvalue -eq 1 ]; then
  rm $SEMAFILE
  cleanup
else
  newvalue=`expr $cntvalue - 1`
  echo $newvalue > $SEMAFILE
fi
